model Brand {
    id          String  @id @default(uuid(7))
    name        String  @db.VarChar(255)
    logo        String? @db.Text
    description String? @db.Text

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    products Product[]

    @@unique([name])
    @@map("brand")
}
